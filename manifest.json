{
  "manifest_version": 3,
  "name": "Shortcut Override for Netflix",
  "short_name": "Shortcut Override",
  "version": "0.2.0",
  "key": "",
  "description": "Customize playback shortcuts on Netflix. Unofficial extension, not affiliated with Netflix.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Shortcut Override",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.netflix.com/*"],
      "js": ["src/content/netflix-api-bridge.ts"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.netflix.com/*"],
      "js": ["src/content/index.ts"],
      "run_at": "document_start"
    }
  ],
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": ["*://*.netflix.com/*"]
}
